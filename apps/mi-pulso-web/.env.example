# Configuración de Mi Pulso (app del paciente)
# MC-MIPULSO-1: Lectura inicial desde API Railway (paciente demo)

# Modo de fuente de datos: "mock" (local) o "api" (Railway)
# Default: "mock" (mantiene el comportamiento previo con mocks)
NEXT_PUBLIC_PULSO_DATA_MODE=mock

# URL base de la API Railway (requerida si NEXT_PUBLIC_PULSO_DATA_MODE=api)
# Ejemplo: https://api-production-42e99.up.railway.app
NEXT_PUBLIC_PULSO_API_BASE_URL=

# Para probar modo api local (CORS ya permite localhost):
#   NEXT_PUBLIC_PULSO_DATA_MODE=api \
#   NEXT_PUBLIC_PULSO_API_BASE_URL=https://api-production-42e99.up.railway.app \
#   pnpm --filter @pulso/mi-pulso-web dev
