# Variables de entorno de la API — solo referencia, sin valores reales.
# Copiar a .env para desarrollo local (nunca commitear .env).

# ─── Servidor ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── Fuente de datos ────────────────────────────────────────────────────────
# "mock"   → comportamiento anterior, default. No requiere DATABASE_URL.
# "prisma" → usa Prisma para endpoints clave. Requiere DATABASE_URL.
# Ver docs/decisiones/0013-api-db-read-key-endpoints.md
PULSO_DATA_SOURCE=mock

# ─── Base de datos ──────────────────────────────────────────────────────────
# Postgres local para desarrollo. Ver docs/decisiones/0012-prisma-persistencia-base.md
#
# IMPORTANTE MC-10.5A:
#   - db:generate → NO requiere DATABASE_URL (solo lee schema.prisma)
#   - db:push     → SÍ requiere DATABASE_URL (conecta a la DB)
#   - db:seed     → SÍ requiere DATABASE_URL (inserta datos demo)
#   - db:studio   → SÍ requiere DATABASE_URL (abre Prisma Studio)
#
# Para desarrollo local con Postgres:
DATABASE_URL="postgresql://usuario:password@localhost:5432/pulso_nutricional_demo?schema=public"

# NO usar credenciales Railway en este archivo.
# NO commitear este archivo con valores reales.
# Railway (no conectar hasta MC correspondiente):
# DATABASE_URL=<se obtiene de Railway dashboard — no hardcodear>

# ─── Railway (no conectar todavía — ver docs/decisiones/0003-api-minima.md) ─
# RAILWAY_ENVIRONMENT=
