{
  "name": "@pulso/api",
  "version": "0.0.0",
  "private": true,
  "description": "API común de Pulso Nutricional. MC-2: API mínima con Fastify y endpoint /health. Sin base de datos ni endpoints de negocio.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "node --watch --experimental-transform-types src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "echo \"[api] lint placeholder — ESLint se configurará en un microciclo posterior\""
  },
  "dependencies": {
    "@pulso/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "fastify": "^5.8.5",
    "pdfkit": "^0.19.0"
  },
  "devDependencies": {
    "@pulso/config": "workspace:*",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.6",
    "typescript": "^5.7.2"
  }
}
